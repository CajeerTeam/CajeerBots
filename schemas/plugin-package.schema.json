{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cajeer Bots plugin package",
  "type": "object",
  "required": [
    "id",
    "version",
    "manifest",
    "artifacts",
    "capabilities"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "manifest": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signature": {
      "type": "string"
    },
    "compatibility": {
      "type": "object"
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
