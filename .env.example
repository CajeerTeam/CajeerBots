# Общие настройки платформы
CAJEER_BOTS_ENV=production
CAJEER_BOTS_MODE=local
CAJEER_BOTS_DEFAULT_TARGET=all
CAJEER_BOTS_INSTANCE_ID=cajeer-bots-01
CAJEER_BOTS_LOG_LEVEL=INFO
CAJEER_BOTS_RUNTIME_DIR=runtime
WORKER_TICK_SECONDS=30

# Единая PostgreSQL-база данных
DATABASE_URL=postgresql://cajeerbots:change-me@127.0.0.1:5432/cajeerbots
DATABASE_SSLMODE=prefer
DATABASE_SCHEMA_SHARED=shared

# Шина событий: memory для одного процесса, redis/postgres для нескольких процессов
EVENT_BUS_BACKEND=memory
LOCAL_INLINE_ROUTING=true
BRIDGE_ROUTING=true
REDIS_URL=

# Docker Compose
POSTGRES_DB=cajeerbots
POSTGRES_USER=cajeerbots
POSTGRES_PASSWORD=change-me-strong-password

# Включение адаптеров
TELEGRAM_ENABLED=true
DISCORD_ENABLED=true
VKONTAKTE_ENABLED=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Discord
DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_MESSAGE_CONTENT_ENABLED=false
DISCORD_SLASH_COMMANDS_ENABLED=true

# ВКонтакте
VK_GROUP_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199
VK_CALLBACK_SECRET=
VK_CONFIRMATION_CODE=

# Модули и плагины
MODULES_ENABLED=identity,rbac,logs,bridge,support,announcements,scheduler,moderation
PLUGINS_ENABLED=example_plugin

# Удалённые журналы
REMOTE_LOGS_ENABLED=false
REMOTE_LOGS_URL=https://logs.example.local/api/v1/ingest
REMOTE_LOGS_TOKEN=
REMOTE_LOGS_TIMEOUT_SECONDS=5

# Безопасность событий и API
EVENT_SIGNING_SECRET=change-me-long-random-secret
API_BIND=127.0.0.1
API_PORT=8088
API_TOKEN=change-me-admin-token
API_TOKEN_READONLY=change-me-readonly-token
API_TOKEN_METRICS=change-me-metrics-token
METRICS_PUBLIC=false

# Дополнительный распределённый режим. Для local mode эти значения не требуются.
DISTRIBUTED_ENABLED=false
DISTRIBUTED_ROLE=
CORE_SERVER_URL=
NODE_ID=
NODE_SECRET=
DISTRIBUTED_TRANSPORT=websocket
DISTRIBUTED_LOCAL_QUEUE_PATH=runtime/distributed-queue.jsonl
DISTRIBUTED_DEGRADED_MODE_ENABLED=true

# Каталоги runtime-модулей и кастомных плагинов. Встроенные bots/modules/plugins упакованы в wheel,
# кастомная бизнес-логика подключается через runtime catalog. В development есть fallback на repo-root.
RUNTIME_CATALOG_PATHS=runtime/catalog
REGISTRY_REPO_ROOT_FALLBACK=true

# Supervisor адаптеров
ADAPTER_RESTART_POLICY=on-failure
ADAPTER_RESTART_MAX=5
ADAPTER_RESTART_BACKOFF_SECONDS=10

# Redis cache/FSM/queues
REDIS_CACHE_PREFIX=cajeer:bots:cache
REDIS_FSM_PREFIX=cajeer:bots:fsm
REDIS_QUEUE_PREFIX=cajeer:bots:queue
DELIVERY_BACKEND=memory
DEAD_LETTER_BACKEND=memory
IDEMPOTENCY_BACKEND=memory
DELIVERY_RETRY_BACKOFF_SECONDS=5
IDEMPOTENCY_TTL_SECONDS=86400

# SQLAlchemy 2.x async + Alembic
DATABASE_ASYNC_URL=postgresql+asyncpg://cajeerbots:change-me@127.0.0.1:5432/cajeerbots
ALEMBIC_CONFIG=alembic.ini

# Cajeer Workspace
CAJEER_WORKSPACE_ENABLED=false
CAJEER_WORKSPACE_URL=https://workspace.cajeer.ru/api/v1
CAJEER_WORKSPACE_TOKEN=
CAJEER_WORKSPACE_PROJECT_ID=
CAJEER_WORKSPACE_TEAM_ID=
CAJEER_WORKSPACE_SERVICE_ID=
CAJEER_WORKSPACE_TIMEOUT_SECONDS=5

# Cajeer Logs ingest API
REMOTE_LOGS_PROJECT=CajeerBots
REMOTE_LOGS_BOT=CajeerBots
REMOTE_LOGS_ENVIRONMENT=production
REMOTE_LOGS_LEVEL=INFO
REMOTE_LOGS_BATCH_SIZE=25
REMOTE_LOGS_FLUSH_INTERVAL=5
REMOTE_LOGS_SIGN_REQUESTS=true

# Тестовый адаптер
FAKE_ENABLED=false
FAKE_SCRIPT=/status

# Версии контрактов интеграций
EVENT_CONTRACT_VERSION=cajeer.bots.event.v1
DB_CONTRACT_VERSION=cajeer.bots.db.v1
WORKSPACE_CONTRACT_VERSION=cajeer.workspace.service.v1
LOGS_CONTRACT_VERSION=cajeer.logs.ingest.v1
API_CONTRACT_VERSION=cajeer.bots.api.v1

# Обновления из GitHub Releases / локальных артефактов
CAJEER_UPDATE_SOURCE=github
CAJEER_UPDATE_REPO=CajeerTeam/CajeerBots
CAJEER_UPDATE_CHANNEL=stable
CAJEER_UPDATE_ALLOW_PRERELEASE=false
CAJEER_UPDATE_INSTALL_ROOT=runtime/updates
CAJEER_UPDATE_LOCAL_ARTIFACT=
CAJEER_UPDATE_LOCAL_MANIFEST=

# Rate limits отправки сообщений
TELEGRAM_RATE_LIMIT_GLOBAL_PER_SECOND=30
VK_RATE_LIMIT_GLOBAL_PER_SECOND=20
DISCORD_RATE_LIMIT_ENABLED=true
