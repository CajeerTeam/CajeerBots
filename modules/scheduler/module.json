{
  "id": "scheduler",
  "name": "Планировщик",
  "version": "1.0.0",
  "type": "module",
  "description": "Фоновые задачи и отложенные действия платформы.",
  "requires": [
    "module:logs",
    "module:bridge"
  ],
  "adapters": [
    "telegram",
    "discord",
    "vkontakte"
  ],
  "enabled_by_default": false,
  "settings_schema": {
    "tick_interval_seconds": {
      "type": "integer",
      "default": 30,
      "description": "Интервал проверки фоновых задач."
    }
  },
  "entrypoint": "modules.scheduler.runtime:SchedulerModule"
}
