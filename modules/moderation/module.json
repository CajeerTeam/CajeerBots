{
  "id": "moderation",
  "name": "Модерация",
  "version": "1.0.0",
  "type": "module",
  "description": "Базовые инструменты модерации сообщений и пользователей.",
  "requires": [
    "module:identity",
    "module:rbac",
    "module:logs"
  ],
  "adapters": [
    "telegram",
    "discord",
    "vkontakte"
  ],
  "enabled_by_default": false,
  "settings_schema": {
    "strict_mode": {
      "type": "boolean",
      "default": false,
      "description": "Включить строгий режим модерации."
    }
  }
}
