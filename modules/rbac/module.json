{
  "id": "rbac",
  "name": "Права доступа",
  "version": "1.0.0",
  "type": "module",
  "description": "Роли, разрешения и проверки доступа для платформы.",
  "requires": [
    "module:identity"
  ],
  "adapters": [
    "telegram",
    "discord",
    "vkontakte"
  ],
  "enabled_by_default": true,
  "settings_schema": {
    "default_role": {
      "type": "string",
      "default": "user",
      "description": "Роль по умолчанию для новых пользователей."
    }
  },
  "entrypoint": "modules.rbac.runtime:RbacModule"
}
