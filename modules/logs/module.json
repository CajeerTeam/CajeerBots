{
  "id": "logs",
  "name": "Журналы",
  "version": "1.0.0",
  "type": "module",
  "description": "Единый слой журналирования и отправки событий в удалённые хранилища.",
  "requires": [],
  "adapters": [
    "telegram",
    "discord",
    "vkontakte"
  ],
  "enabled_by_default": true,
  "settings_schema": {
    "remote_batch_size": {
      "type": "integer",
      "default": 100,
      "description": "Размер пачки для отправки журналов."
    }
  },
  "entrypoint": "modules.logs.runtime:LogsModule"
}
